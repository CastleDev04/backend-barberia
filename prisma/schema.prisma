generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Encargados {
  id         Int      @id @default(autoincrement())
  created_at DateTime @default(now()) @db.Timestamptz(6)
  nombre     String?  @db.VarChar
  apellido   String?  @db.VarChar
  telefono   String?  @db.VarChar
  correo     String?  @db.VarChar
  password   String?  @db.VarChar
  salario    Float?   @db.Real
  estado     String?  @db.VarChar
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model clientes {
  id         Int      @id @default(autoincrement())
  created_at DateTime @default(now()) @db.Timestamptz(6)
  nombre     String?  @db.VarChar
  apellido   String?  @db.VarChar
  telefono   String?  @db.VarChar
  correo     String?  @db.VarChar
  password   String?  @db.VarChar
  turnos     turnos[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model detalle_turno {
  id_detalle_turno Int       @id @default(autoincrement())
  id_turno         Int
  id_servicio      Int
  precio_servicio  Decimal   @db.Decimal(10, 2)
  duracion         Int
  servicios        servicios @relation(fields: [id_servicio], references: [id_servicio], onDelete: NoAction, onUpdate: NoAction)
  turnos           turnos    @relation(fields: [id_turno], references: [id_turno], onDelete: NoAction, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model gastos {
  id_gasto    Int      @id @default(autoincrement())
  concepto    String   @db.VarChar(200)
  monto       Decimal  @db.Decimal(10, 2)
  fecha       DateTime @db.Date
  observacion String?
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model pagos {
  id_pago     Int      @id @default(autoincrement())
  id_turno    Int
  monto       Decimal  @db.Decimal(10, 2)
  metodo_pago String   @db.VarChar(50)
  fecha       DateTime @db.Date
  estado      String   @db.VarChar(20)
  turnos      turnos   @relation(fields: [id_turno], references: [id_turno], onDelete: NoAction, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model servicios {
  id_servicio     Int             @id @default(autoincrement())
  nombre_servicio String          @db.VarChar(100)
  descripcion     String?
  precio          Decimal         @db.Decimal(10, 2)
  duracion        Int
  detalle_turno   detalle_turno[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model turnos {
  id_turno      Int             @id @default(autoincrement())
  id_cliente    Int
  id_barbero    Int
  fecha         DateTime        @db.Date
  estado        String          @db.VarChar(20)
  hora_inicio   String?         @db.VarChar(5)
  hora_fin      String?         @db.VarChar(5)
  detalle_turno detalle_turno[]
  pagos         pagos[]
  barberos      barberos        @relation(fields: [id_barbero], references: [id_barbero], onDelete: NoAction, onUpdate: NoAction)
  clientes      clientes        @relation(fields: [id_cliente], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model barberos {
  id_barbero       Int                @id @default(autoincrement())
  nombres          String             @db.VarChar(100)
  apellido         String             @db.VarChar(100)
  telefono         String?            @db.VarChar(20)
  correo           String?            @unique @db.VarChar(100)
  password         String             @db.VarChar(255)
  salario          Decimal?           @db.Decimal(10, 2)
  especialidad     String?            @db.VarChar(100)
  estado           String?            @db.VarChar(20)
  horarios_barbero horarios_barbero[]
  turnos           turnos[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model horarios_barbero {
  id_horario  Int      @id @default(autoincrement())
  id_barbero  Int
  dia_semana  Int
  hora_inicio String
  hora_fin    String
  barberos    barberos @relation(fields: [id_barbero], references: [id_barbero], onDelete: Cascade, onUpdate: NoAction, map: "fk_barbero")
}
